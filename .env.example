# Copy to .env and fill in. Or use credentials.json (see credentials.json.example).
# Values below match STT_Credentials_Engineering doc where applicable.

# AWS Transcribe (Streaming API)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-southeast-1

# Azure Speech (Cognitive Services). Doc had key truncated – paste full key when shared.
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus2

# Google Cloud Speech-to-Text v2
GOOGLE_APPLICATION_CREDENTIALS=Aiello_Google (1)/Aiello Chatbot.json
GOOGLE_PROJECT_ID=aiellochatbot

# Speechmatics (batch ASR)
SPEECHMATICS_API_KEY=your_speechmatics_api_key

# ElevenLabs (Speech-to-Text)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Groq (Whisper)
GROQ_API_KEY=your_groq_api_key

# Optional: override audio files for run_stt_comparison.py
# AUDIO_WAV=9e702cefb81ebbfd4ed298a196dde1fd4e07630f.wav
# AUDIO_MP3=9e702cefb81ebbfd4ed298a196dde1fd4e07630f.mp3
